# Admin Dashboard Configuration
# ============================================================
# Salin file ini ke .env dan sesuaikan nilainya
# JANGAN commit file .env ke Git!
# ============================================================

# Backend API URL
# Development : http://localhost:8000
# Production  : https://api.yourdomain.com
ADMIN_API_BASE_URL=http://localhost:8000

# Password untuk masuk ke halaman login dashboard
# Ganti nilai ini jika password bocor, lalu restart dashboard
# Contoh generate password kuat: python -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_PASSWORD=ganti-dengan-password-kuat-anda

# Secret key untuk autentikasi request dari dashboard ke backend API
# HARUS sama dengan nilai ADMIN_KEY di backend/.env
# Ganti keduanya BERSAMAAN jika key ini bocor
ADMIN_KEY=ganti-dengan-secret-key-yang-sama-dengan-backend
