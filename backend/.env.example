# Database Configuration (REQUIRED — no default in config.py)
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/rasa_id_db

# Admin API Key (REQUIRED — no default in dashboard)
ADMIN_KEY=your_secure_admin_key_here

# Storage Configuration
STORAGE_PATH=./storage

# CORS Configuration (comma-separated origins)
# Add your production domain before deployment
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://app.domainkita.com

# Model Configuration
MODEL_PATH=./storage/models/best.pt
CONF_THRESHOLD=0.25
IOU_THRESHOLD=0.45

# Reliability & Limits
MAX_UPLOAD_SIZE=10485760
DETECT_TIMEOUT_SECONDS=30
DETECT_MAX_CONCURRENCY=2
