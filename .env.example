# =============================================================================
# RASA-ID Environment Variables
# =============================================================================
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai.
# JANGAN commit file .env ke git!
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL Database
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ganti_dengan_password_kuat_disini
POSTGRES_DB=rasa_id_db

# ---------------------------------------------------------------------------
# Backend (FastAPI)
# ---------------------------------------------------------------------------
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql+psycopg2://postgres:ganti_dengan_password_kuat_disini@db:5432/rasa_id_db

# Admin API Key — WAJIB diganti dengan string acak panjang sebelum deploy!
# Cara generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_KEY=ganti_dengan_kunci_admin_acak_yang_panjang

# Password untuk login ke Admin Dashboard
DASHBOARD_PASSWORD=ganti_dengan_password_dashboard_anda

# CORS — URL frontend yang diizinkan mengakses backend
# Development: http://localhost:5173
# Production: ganti dengan domain Anda, contoh: https://rasa-id.example.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Storage & Model
STORAGE_PATH=./storage
MODEL_PATH=./storage/models/best.pt
CONF_THRESHOLD=0.5

# Environment mode: development | production
# production mode: uvicorn runs with multiple workers (no hot-reload)
APP_ENV=production

# ---------------------------------------------------------------------------
# Frontend (Vite React)
# ---------------------------------------------------------------------------
# URL Backend yang dapat diakses dari browser user (bukan dari dalam Docker)
# Development: http://localhost:8000
# Production: https://api.rasa-id.example.com  (domain publik server Anda)
VITE_API_BASE_URL=http://localhost:8000
